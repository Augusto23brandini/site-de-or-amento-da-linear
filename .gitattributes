# Normalize line endings for text files
* text=auto

# Explicitly set file types
*.html text
*.css text
*.js text
*.json text
*.md text
*.svg text
*.yml text
*.yaml text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
